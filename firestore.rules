rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    
    function incoming() {
      return request.resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection - special case for internal auth
    match /admins/{adminId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    match /website_config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    match /programs/{programId} {
      allow read: if true;
      allow write: if true;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if true;
    }

    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if true;
    }

    match /kesantrian/{activityId} {
      allow read: if true;
      allow write: if true;
    }

    match /students/{studentId} {
      allow read: if true;
      allow write: if true;
    }

    match /permits/{permitId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
